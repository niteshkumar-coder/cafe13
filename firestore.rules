rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - name: string (required) - User's full name
    //   - phone: string (required) - User's verified phone number
    //   - createdAt: timestamp (optional) - Account creation time
    //
    // Collection: orders
    // Document ID: {orderId} (auto-generated)
    // Fields:
    //   - userId: string (required) - UID of the user who placed the order
    //   - items: list (required) - List of ordered items
    //   - total: string (required) - Total order amount
    //   - status: string (required) - Current status (pending, preparing, delivered, cancelled)
    //   - createdAt: timestamp (required) - Order placement time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'phone']) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.matches("^\\+?[1-9][0-9]{1,14}$");
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'userName', 'userPhone', 'items', 'total', 'tableNo', 'paymentMethod', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 &&
             data.userPhone is string &&
             data.items is list && data.items.size() > 0 && data.items.size() < 50 &&
             data.total is string &&
             data.tableNo is string &&
             data.paymentMethod in ['online', 'cod'] &&
             data.status in ['pending', 'preparing', 'delivered', 'cancelled'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid;
    }

    match /orders/{orderId} {
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if false; 
      allow delete: if false;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
